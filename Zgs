  projectId: "bpmhs-digital-hub",
  storageBucket: "bpmhs-digital-hub.firebasestorage.app",
  messagingSenderId: "738111789238",
  appId: "1:738111789238:web:7659305c6a2beeaeb8ae17",
  measurementId: "G-WPG8R7LTVR"
};
        // ============================================

